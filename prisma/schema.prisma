// Easy Management AI - Phase 2 Postgres Schema
// Este esquema refleja todo el feedback recogido durante la Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. El Mandante (Cuenta Principal / Tenant)
// Aquí guardaremos el logo del mandante, nombre y sus metas globales.
model Tenant {
  id              String   @id @default(cuid())
  name            String
  logoUrl         String?
  annualGoalUsd   Float?   // Meta Anual en Dólares u otra Moneda
  monthlyGoalUsd  Float?   // Meta Mensual
  
  users           User[]
  clients         Client[]
  opportunities   Opportunity[]
  createdAt       DateTime @default(now())
}

// 2. Usuarios (Tú y tu equipo de ventas)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String?
  profileImage String?
  country      String?
  clientUrl    String?
  logoUrl      String?
  avatarUrl    String?
  demoData     String?
  isPro        Boolean  @default(false)
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  
  activities   ActivityLog[]
}

// 3. Clientes / Distribuidores (Lo que faltaba para emparejar a "Perú", etc.)
model Client {
  id           String   @id @default(cuid())
  name         String   // Ej: "Telefónica del Perú" o "Distribuidor Local S.A."
  country      String   // Ej: "Perú", "Brasil"
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  
  opportunities Opportunity[]
  activities    ActivityLog[]
}

// 4. Oportunidades (El embudo de ventas: Montos y Estados)
enum OpportunityStatus {
  PROSPECTO
  COTIZADO
  GANADO
  PERDIDO
}

model Opportunity {
  id           String   @id @default(cuid())
  title        String   // Ej: "Venta de herramientas de telecomunicaciones"
  amountUsd    Float    // Monto de la Oportunidad
  status       OpportunityStatus @default(PROSPECTO)
  confidenceLevel String @default("MEDIA")
  
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  
  activities   ActivityLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 5. Bitácora de Acción y IA (Las tareas y el NLP)
model ActivityLog {
  id             String   @id @default(cuid())
  rawAudioText   String?  // El texto crudo que reconoció la IA
  extractedAction String? // Lo que la IA entendió que hay que hacer ("Enviar Cotización")
  commitmentDate DateTime? // La fecha calendario calculada por la IA
  completed      Boolean  @default(false) // Permite diferenciar tareas pendientes de atendidas
  
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id])
  
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  createdAt      DateTime @default(now()) // La Hora y Fecha exacta e inmutable del registro
}
