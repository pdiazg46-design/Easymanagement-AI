// Easy Management AI - Phase 2 Postgres Schema
// Este esquema refleja todo el feedback recogido durante la Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. El Mandante (Cuenta Principal / Tenant)
// Aquí guardaremos el logo del mandante, nombre y sus metas globales.
model Tenant {
  id              String   @id @default(cuid())
  name            String
  logoUrl         String?
  annualGoalUsd   Float?   // Meta Anual en Dólares u otra Moneda
  monthlyGoalUsd  Float?   // Meta Mensual
  
  users           User[]
  clients         Client[]
  opportunities   Opportunity[]
  catalogItems    CatalogItem[]
  createdAt       DateTime @default(now())
}

// Model para el Catálogo RAG de productos
model CatalogItem {
  id        String   @id @default(cuid())
  name      String
  price     Float
  stock     String   @default("Disponible")
  
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId    String?   // Dueño del dato para aislamiento total
  user      User?     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}

// 2. Usuarios (Tú y tu equipo de ventas)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String?
  profileImage String?
  country      String?
  clientUrl    String?
  logoUrl      String?
  avatarUrl    String?
  demoData     String?
  isPro        Boolean  @default(false)
  proSince     DateTime?
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime  @default(now())

  // Metas Personales (Para aislamiento total)
  monthlyGoalUsd Float?   @default(80000)
  annualGoalUsd  Float?   @default(1000000)
  
  activities   ActivityLog[]
  clients      Client[]
  opportunities Opportunity[]
  catalogItems CatalogItem[]
  subscriptions PushSubscription[]
}

// 3. Clientes / Distribuidores
model Client {
  id           String   @id @default(cuid())
  name         String   
  country      String   
  region       String?  
  
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  
  userId       String?   // Dueño del dato
  user         User?     @relation(fields: [userId], references: [id])

  opportunities Opportunity[]
  activities    ActivityLog[]
}

// 4. Oportunidades (El embudo de ventas: Montos y Estados)
enum OpportunityStatus {
  PROSPECTO
  COTIZADO
  GANADO
  PERDIDO
}

model Opportunity {
  id           String   @id @default(cuid())
  title        String   
  amountUsd    Float    
  status       OpportunityStatus @default(PROSPECTO)
  confidenceLevel String @default("MEDIA")
  
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  
  userId       String?   // Dueño del dato
  user         User?     @relation(fields: [userId], references: [id])
  
  activities   ActivityLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  statusUpdatedAt DateTime? @default(now())
}

// 5. Bitácora de Acción y IA (Las tareas y el NLP)
model ActivityLog {
  id             String   @id @default(cuid())
  rawAudioText   String?  // El texto crudo que reconoció la IA
  extractedAction String? // Lo que la IA entendió que hay que hacer ("Enviar Cotización")
  commitmentDate DateTime? // La fecha calendario calculada por la IA
  completed      Boolean  @default(false) // Permite diferenciar tareas pendientes de atendidas
  
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  createdAt      DateTime @default(now()) // La Hora y Fecha exacta e inmutable del registro
}

// 6. Push Subscriptions para Notificaciones (VAPID)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
